{
    "manifest_version": 3,
    "name": "clouder",
    "version": "2.0.0",
    "description": "AI-powered Canvas workbench with style transfer, sketch-to-image, and local editing using Qwen API",
    "author": "Qwen Canvas Workbench Team",
    "permissions": [
        "activeTab",
        "storage",
        "scripting",
        "sidePanel",
        "contextMenus",
        "windows"
    ],
    "host_permissions": [
        "https://gemini.google.com/*",
        "https://aistudio.google.com/*",
        "https://dashscope.aliyuncs.com/*",
        "https://api.yunjintao.com/*",
        "https://api.replicate.com/*"
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "icons/*"
            ],
            "matches": [
                "https://gemini.google.com/*",
                "https://aistudio.google.com/*"
            ]
        }
    ],
    "action": {
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        },
        "default_title": "Qwen Canvas Workbench"
    },
    "side_panel": {
        "default_path": "sidepanel.html"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://gemini.google.com/*",
                "https://aistudio.google.com/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_end"
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}